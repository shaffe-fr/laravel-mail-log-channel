{
    "name": "shaffe/laravel-mail-log-channel",
    "description": "A package to support logging via email in Laravel",
    "homepage": "https://github.com/shaffe-fr/laravel-mail-log-channel",
    "license": "MIT",
    "keywords": [
        "laravel",
        "logging",
        "mail channel",
        "laravel-log-mailer",
        "monolog",
        "laravel-mail-log-channel",
        "shaffe"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/bus": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/log": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Shaffe\\MailLogChannel\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shaffe\\MailLogChannel\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "Karel FAILLE",
            "email": "shaffe.fr@gmail.com",
            "role": "Developer"
        },
        {
            "name": "Steve Porter",
            "email": "steve@designmynight.com",
            "role": "Developer"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Shaffe\\MailLogChannel\\MailLogChannelServiceProvider"
            ]
        }
    }
}
